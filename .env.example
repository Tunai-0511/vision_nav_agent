# 把這個檔案複製成 .env 並填入你自己的值
# .env 已經被 .gitignore 排除，安全

# OpenClaw 認證 token（用於 Vision 分析器）
# 預設值為本機 development token，正式環境請替換
OPENCLAW_TOKEN=

# Telegram Bot (給每日總結 / 商品辨識通知用)
# 取得方式：
#   1. 在 Telegram 找 @BotFather → /newbot → 取名 → 拿到 token
#   2. 跟你的新 bot 對話，隨便傳一句訊息
#   3. 開瀏覽器 https://api.telegram.org/bot<TOKEN>/getUpdates
#      在 JSON 中找 "chat":{"id":123456789} 那個數字就是 chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
